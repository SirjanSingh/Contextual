# Repo-Aware AI — Environment Configuration
#
# Copy this file to `.env` and fill in your Google API key. The .env file is
# gitignored so your key never lands in source control.
#
#   cp .env.example .env
#
# Get a key from: https://aistudio.google.com/app/apikey

# ---- Required ----
# Google Gemini API key. Used for both LLM completion and embeddings.
GOOGLE_API_KEY=

# ---- Optional ----
# LLM model for answer generation. Default: models/gemini-2.5-flash
# GEMINI_MODEL=models/gemini-2.5-flash

# Embedding model. Default: gemini-embedding-001 (768 dimensions).
# EMBEDDING_MODEL=gemini-embedding-001

# Backend server port (used by `repo-aware-ai-server` and the VS Code extension).
# RAI_PORT=8360

# Cache directory for the FAISS index + metadata. Default: data/index
# RAI_DATA_DIR=data/index

# Auto-index this folder on server startup (dev convenience). Unset by default.
# RAI_AUTO_INDEX=/absolute/path/to/your/repo
