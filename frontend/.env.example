# Frontend environment configuration.
# Copy this file to `.env` (or `.env.local`) and edit as needed.
#
# In development (`npm run dev`), Vite proxies API calls to the backend, so you
# normally don't need to set anything here. Set VITE_BACKEND_URL only when:
#   - You want the dev proxy to point at a non-default backend, or
#   - You're building for production and serving the SPA from a host that is
#     NOT the same origin as the FastAPI backend.

# Absolute backend URL. Examples:
#   http://localhost:8360             (default)
#   https://repo-ai.example.com       (remote prod backend)
#
# WebSocket URLs are derived from this by replacing http -> ws.
# VITE_BACKEND_URL=http://localhost:8360
